# Loregraph backend configuration.
# Copy to .env and fill in your values. All variables use the CAMPAIGN_ prefix
# and map to Settings in src/loregraph/config.py. Never commit .env.

# --- General ---
# Directory for all persistent data (sqlite, chroma, attachments).
CAMPAIGN_DATA_DIR=./data
# JSON array (pydantic-settings parses list fields as JSON).
CAMPAIGN_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
CAMPAIGN_LOG_LEVEL=INFO

# --- LLM (BYOK) ---
# Set CAMPAIGN_LLM_PROVIDER to one of:
#   anthropic | openai | ollama | google | mistral | deepseek | groq
#   xai | openrouter | cohere | together | fireworks | cerebras
#   perplexity | nebius
#
# Then set the corresponding API key. Only the active provider's key is needed.
CAMPAIGN_LLM_PROVIDER=anthropic

# Anthropic (default)
CAMPAIGN_ANTHROPIC_API_KEY=

# OpenAI
# CAMPAIGN_OPENAI_API_KEY=

# Ollama (local, no key needed)
# CAMPAIGN_OLLAMA_BASE_URL=http://localhost:11434

# Google Gemini
# CAMPAIGN_GOOGLE_API_KEY=

# Mistral
# CAMPAIGN_MISTRAL_API_KEY=

# DeepSeek
# CAMPAIGN_DEEPSEEK_API_KEY=

# Groq (fast inference)
# CAMPAIGN_GROQ_API_KEY=

# xAI (Grok)
# CAMPAIGN_XAI_API_KEY=

# OpenRouter (aggregator — access to 100+ models)
# CAMPAIGN_OPENROUTER_API_KEY=

# Cohere
# CAMPAIGN_COHERE_API_KEY=

# Together AI
# CAMPAIGN_TOGETHER_API_KEY=

# Fireworks AI
# CAMPAIGN_FIREWORKS_API_KEY=

# Cerebras (fastest inference)
# CAMPAIGN_CEREBRAS_API_KEY=

# Perplexity (OpenAI-compatible)
# CAMPAIGN_PERPLEXITY_API_KEY=
# CAMPAIGN_PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Nebius (OpenAI-compatible)
# CAMPAIGN_NEBIUS_API_KEY=
# CAMPAIGN_NEBIUS_BASE_URL=https://api.staging.nebius.com/v1

# One model per task class (see CLAUDE.md, "Модель и температура по типу задачи").
# Defaults are Anthropic model ids; override all three when switching provider.
#   assistant  — the chat loop (tool routing + short replies). Highest-frequency
#                caller and the biggest recurring cost: keep it cheap.
#   extraction — deterministic verification (grounding judge).
#   generation — creative lore batches.
CAMPAIGN_LLM_MODEL_ASSISTANT=claude-haiku-4-5-20251001
CAMPAIGN_LLM_MODEL_EXTRACTION=claude-haiku-4-5-20251001
CAMPAIGN_LLM_MODEL_GENERATION=claude-sonnet-5

# --- Agent ---
# Hard per-run token ceiling; exceeding it interrupts into human_review.
CAMPAIGN_AGENT_RUN_TOKEN_BUDGET=200000
CAMPAIGN_WEB_SEARCH_ENABLED=false
# Cache the stable generate_lore prefix (retrieved lore + knowledge base +
# brief) so regenerations re-read it instead of re-paying. Anthropic-only;
# ignored on other providers.
CAMPAIGN_AGENT_PROMPT_CACHING=true

# --- Embeddings / vector store ---
# One of: local | openai | google | mistral | cohere | together | fireworks | ollama | disabled
#   local    — multilingual ONNX model via fastembed, lore never leaves the machine
#   openai   — explicit opt-in trade of privacy for quality (needs OPENAI_API_KEY above)
#   google   — Google embedding model (needs GOOGLE_API_KEY above)
#   mistral  — Mistral embedding model (needs MISTRAL_API_KEY above)
#   cohere   — Cohere embedding model (needs COHERE_API_KEY above)
#   together — Together AI embedding model (needs TOGETHER_API_KEY above)
#   fireworks — Fireworks AI embedding model (needs FIREWORKS_API_KEY above)
#   ollama   — local embedding model via Ollama (needs Ollama running)
#   disabled — no vector indexing (manual editor works; agent retrieval degrades)
CAMPAIGN_EMBEDDING_PROVIDER=local
CAMPAIGN_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CAMPAIGN_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CAMPAIGN_GOOGLE_EMBEDDING_MODEL=gemini-embedding-2-preview
# CAMPAIGN_MISTRAL_EMBEDDING_MODEL=mistral-embed
# CAMPAIGN_COHERE_EMBEDDING_MODEL=embed-english-light-v3.0
# CAMPAIGN_TOGETHER_EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
# CAMPAIGN_FIREWORKS_EMBEDDING_MODEL=accounts/fireworks/models/fireworks-v1
# CAMPAIGN_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
